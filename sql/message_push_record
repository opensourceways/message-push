create table message_push_record
(
    recipient_id text,
    time_uuid    timeuuid,
    created_at   timestamp,
    data         map<text, text>,
    event_id     text,
    push_address text,
    push_state   text,
    push_time    timestamp,
    push_type    text,
    remark       text,
    source       text,
    primary key (recipient_id, time_uuid)
)
            with clustering order by (time_uuid desc);

create index message_push_record_source_index
    on message_push_record (source);

